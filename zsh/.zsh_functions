# ============================================
# proj — tmux session switcher (fzf)
# ============================================

# fzf-based tmux session switcher as a zsh widget.
# Only useful inside tmux; binding is guarded accordingly.
_proj_fzf_session() {
  local sessions
  sessions=$(tmux list-sessions -F '#{session_name}' 2>/dev/null) || {
    zle -M "No tmux sessions found."
    return
  }
  local selected
  selected=$(echo "$sessions" | fzf-tmux -p --prompt="session: " --reverse)
  [[ -z "$selected" ]] && return
  tmux switch-client -t "=$selected"
  zle reset-prompt
}
zle -N _proj_fzf_session

# Only bind inside tmux — fzf-tmux requires a running tmux server
[[ -n "$TMUX" ]] && bindkey '^F' _proj_fzf_session
