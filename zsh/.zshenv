export GOPATH="$HOME/.local/share/go"
export CARGO_HOME="$HOME/.local/share/cargo"
export RUSTUP_HOME="$HOME/.local/share/rustup"
. "$HOME/.local/share/cargo/env"
export PYENV_ROOT="$HOME/.local/share/pyenv"
export PATH="$PYENV_ROOT/bin:$PATH"
eval "$(pyenv init -)"
export GRADLE_USER_HOME="$HOME/.local/share/gradle"
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_CACHE_HOME="$HOME/.cache"
export XDG_STATE_HOME="$HOME/.local/state"
export DOCKER_CONFIG="$HOME/.config/docker"
export AZURE_CONFIG_DIR="$HOME/.config/azure"
export GNUPGHOME="$HOME/.config/gnupg"
export WGETRC="$HOME/.config/wget/wgetrc"
export INPUTRC="$HOME/.config/readline/inputrc"
export SQLITE_HISTORY="$HOME/.local/state/sqlite_history"
export PYTHON_HISTORY="$HOME/.local/state/python_history"
export LESSHISTFILE="$HOME/.local/state/less/history"
